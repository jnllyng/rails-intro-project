<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Bookshelf</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </head>
  <body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <%= link_to "Bookshelf", root_path, class: "navbar-brand" %>
        <div class="navbar-nav ms-auto">
          <%= link_to "Books", books_path, class: "nav-link text-white" %>
          <%= link_to "Authors", authors_path, class: "nav-link text-white" %>
          <%= link_to "Genres", genres_path, class: "nav-link text-white" %>
          <%= link_to "About", about_path, class: "nav-link text-white" %>
        </div>
      </div>
    </nav>

    <div class="container mt-4">
      <%= yield %>
    </div>

  </body>
</html>