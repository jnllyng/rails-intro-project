<div class="row mt-4">
  <div class="col-md-8 mx-auto">
    <h1><%= @author.name %></h1>
    <p class="text-muted"><%= @author.nationality %></p>
    <p><%= @author.bio %></p>
    <hr>
    <h2 class="mb-4">Books by <%= @author.name %></h2>
    <div class="row row-cols-1 row-cols-md-3 g-4">
      <% @books.each do |book| %>
        <div class="col">
          <div class="card h-100">
            <% if book.cover_image.present? %>
              <img src="<%= book.cover_image %>" class="card-img-top" alt="<%= book.title %>" style="height: 200px; object-fit: cover;">
            <% end %>
            <div class="card-body">
              <p class="text-muted mb-1" style="font-size: 0.75rem; text-transform: uppercase;"><%= book.genre.name %></p>
              <h3 class="card-title" style="font-size: 1rem;"><%= book.title %></h3>
            </div>
            <div class="card-footer">
              <%= link_to "View Details", book_path(book), class: "btn btn-dark w-100" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
    <div class="mt-4">
      <%= link_to "← Back to Authors", authors_path, class: "btn btn-outline-dark" %>
    </div>
  </div>
</div>