<h1 class="mb-4">Genres</h1>

<div class="row row-cols-1 row-cols-md-3 g-4">
  <% @genres.each do |genre| %>
    <div class="col">
      <div class="card h-100">
        <div class="card-body text-center py-5">
          <h2 class="card-title"><%= genre.name %></h2>
          <p class="text-muted"><%= genre.description %></p>
          <span class="badge bg-secondary"><%= genre.books.count %> books</span>
        </div>
        <div class="card-footer">
          <%= link_to "Browse Books", genre_path(genre), class: "btn btn-dark w-100" %>
        </div>
      </div>
    </div>
  <% end %>
</div>