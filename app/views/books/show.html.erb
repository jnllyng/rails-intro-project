<div class="row mt-4">
  <div class="col-md-3">
    <% if @book.cover_image.present? %>
      <img src="<%= @book.cover_image %>" class="img-fluid rounded" alt="<%= @book.title %>">
    <% else %>
      <div class="bg-secondary d-flex align-items-center justify-content-center rounded" style="height: 350px;">
        <span class="text-white">No Cover</span>
      </div>
    <% end %>
  </div>
  <div class="col-md-9 ps-5">
    <p class="text-muted mb-1" style="font-size: 0.85rem; text-transform: uppercase;">
      <%= link_to @book.genre.name, genre_path(@book.genre) %>
    </p>
    <h1><%= @book.title %></h1>
    <p class="text-muted">by <%= link_to @book.author.name, author_path(@book.author) %></p>
    <hr>
    <p><%= @book.description %></p>
    <ul class="list-unstyled">
      <li><strong>Published:</strong> <%= @book.published_year %></li>
      <li><strong>Pages:</strong> <%= @book.pages %></li>
      <li><strong>Rating:</strong> ⭐ <%= @book.rating %></li>
    </ul>
    <%= link_to "← Back to Books", books_path, class: "btn btn-outline-dark mt-2" %>
  </div>
</div>

<hr class="mt-5">
<h2 class="mb-4">Reviews</h2>
<% if @reviews.any? %>
  <div class="row row-cols-1 row-cols-md-2 g-4">
    <% @reviews.each do |review| %>
      <div class="col">
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title"><%= review.reviewer_name %></h5>
            <p class="text-muted">⭐ <%= review.rating %></p>
            <p><%= review.body %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-muted">No reviews yet.</p>
<% end %>