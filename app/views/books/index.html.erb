<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Books</h1>
  <%= form_with url: books_path, method: :get, local: true do |f| %>
    <div class="input-group">
      <%= f.text_field :search, value: params[:search], placeholder: "Search books...", class: "form-control" %>
      <%= f.submit "Search", class: "btn btn-dark" %>
    </div>
  <% end %>
</div>

<% if params[:search].present? %>
  <p class="text-muted"><%= @books.count %> results for "<%= params[:search] %>" <%= link_to "Clear", books_path %></p>
<% end %>

<div class="row row-cols-1 row-cols-md-4 g-4">
  <% @books.each do |book| %>
    <div class="col">
      <div class="card h-100">
        <% if book.cover_image.present? %>
          <img src="<%= book.cover_image %>" class="card-img-top" alt="<%= book.title %>" style="height: 250px; object-fit: cover;">
        <% else %>
          <div class="bg-secondary d-flex align-items-center justify-content-center" style="height: 250px;">
            <span class="text-white">No Cover</span>
          </div>
        <% end %>
        <div class="card-body">
          <p class="text-muted mb-1" style="font-size: 0.75rem; text-transform: uppercase;"><%= book.genre.name %></p>
          <h2 class="card-title" style="font-size: 1rem;"><%= book.title %></h2>
          <p class="text-muted" style="font-size: 0.85rem;"><%= book.author.name %></p>
          <p><strong>⭐ <%= book.rating %></strong></p>
        </div>
        <div class="card-footer">
          <%= link_to "View Details", book_path(book), class: "btn btn-dark w-100" %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<div class="row mt-5">
  <div class="col-12 d-flex justify-content-center">
    <%= paginate @books %>
  </div>
</div>